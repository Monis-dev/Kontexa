{
  "manifest_version": 3,
  "name": "ContextNote | Research Assistant",
  "version": "1.0",
  "description": "Highlight, annotate, and save research directly from your browser.",
  "permissions": [
    "contextMenus",
    "storage",
    "unlimitedStorage",
    "scripting",
    "activeTab",
    "tabs"
  ],
  "host_permissions": ["<all_urls>", "https://generativelanguage.googleapis.com/*", "https://context-notes.onrender.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>", "https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "commands": {
    "save-highlight-shortcut": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Save selected text as a ContextNote highlight"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard/dashboard.html", "dashboard/dashboard.js", "pro.js", "ai_service.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "24": "icons/icon-24.png",
    "64": "icons/icon-64.png",
    "128": "icons/icon-128.png"
  }
}